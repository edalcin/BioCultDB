<article class="result-card" x-data="{ expanded: false }" @expand-all.window="expanded = true" @collapse-all.window="expanded = false">
  <!-- Reference Header - Clickable -->
  <header
    class="border-b border-gray-200 pb-3 mb-3 cursor-pointer hover:bg-gray-50 -m-4 p-4 rounded-t-lg transition-colors"
    @click="expanded = !expanded"
  >
    <div class="flex items-start justify-between gap-2">
      <div class="flex-1">
        <h3 class="text-lg font-semibold text-gray-900 mb-1">
          <%= reference.titulo %>
        </h3>

        <div class="text-sm text-gray-600">
          <p class="mb-1">
            <strong>Autores:</strong> <%= reference.autores.join(', ') %>
          </p>
          <p>
            <strong>Ano:</strong> <%= reference.ano %>
            <% if (reference.DOI && reference.DOI.trim().length > 0) { %>
              | <strong>DOI:</strong> <%= reference.DOI %>
            <% } %>
          </p>
        </div>
      </div>

      <!-- Expand/Collapse Icon -->
      <div class="flex-shrink-0 text-gray-400">
        <svg
          x-show="!expanded"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
        <svg
          x-show="expanded"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
        </svg>
      </div>
    </div>

    <div x-show="!expanded" class="mt-2 text-sm text-gray-500">
      <%= reference.comunidades.length %> comunidade<%= reference.comunidades.length !== 1 ? 's' : '' %>
    </div>
  </header>

  <!-- Reference Details - Collapsible -->
  <div
    x-show="expanded"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 transform -translate-y-2"
    x-transition:enter-end="opacity-100 transform translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 transform translate-y-0"
    x-transition:leave-end="opacity-0 transform -translate-y-2"
  >
    <!-- Abstract (if available) -->
    <% if (reference.resumo && reference.resumo.trim().length > 0) { %>
      <div class="mb-4">
        <p class="text-sm text-gray-700">
          <%= reference.resumo %>
        </p>
      </div>
    <% } %>

    <!-- Communities Section -->
    <div class="space-y-3">
      <h4 class="text-sm font-semibold text-gray-800 mb-3">
        Comunidades (<%= reference.comunidades.length %>)
      </h4>

      <% reference.comunidades.forEach((comunidade, index) => { %>
        <div
          class="bg-gray-50 rounded-lg overflow-hidden"
          x-data="{ communityExpanded: false }"
        >
          <!-- Community Header - Clickable -->
          <div
            class="p-3 cursor-pointer hover:bg-gray-100 transition-colors"
            @click="communityExpanded = !communityExpanded"
          >
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1">
                <p class="font-medium text-gray-900"><%= comunidade.nome %></p>
                <p class="text-sm text-gray-600">
                  <% if (comunidade.municipio && comunidade.municipio.trim()) { %>
                    <%= comunidade.municipio %>, <%= comunidade.estado %>
                  <% } else { %>
                    <%= comunidade.estado %>
                  <% } %>
                </p>
              </div>

              <!-- Expand/Collapse Icon -->
              <div class="flex-shrink-0 text-gray-400">
                <svg
                  x-show="!communityExpanded"
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
                <svg
                  x-show="communityExpanded"
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
              </div>
            </div>

            <div x-show="!communityExpanded" class="mt-1 text-xs text-gray-500">
              <% if (comunidade.plantas && comunidade.plantas.length > 0) { %>
                <%= comunidade.plantas.length %> planta<%= comunidade.plantas.length !== 1 ? 's' : '' %>
              <% } %>
            </div>
          </div>

          <!-- Community Details - Collapsible -->
          <div
            x-show="communityExpanded"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="px-3 pb-3"
          >
            <!-- Economic Activities (if available) -->
            <% if (comunidade.atividadesEconomicas && comunidade.atividadesEconomicas.length > 0) { %>
              <div class="border-t border-gray-200 pt-2 mt-2">
                <p class="text-xs text-gray-700">
                  <strong>Atividades Econômicas:</strong>
                  <%= comunidade.atividadesEconomicas.join(', ') %>
                </p>
              </div>
            <% } %>

            <!-- Observations (if available) -->
            <% if (comunidade.observacoes && comunidade.observacoes.trim().length > 0) { %>
              <div class="border-t border-gray-200 pt-2 mt-2">
                <p class="text-xs text-gray-700">
                  <strong>Observações:</strong> <%= comunidade.observacoes %>
                </p>
              </div>
            <% } %>

            <!-- Plants Grid -->
            <% if (comunidade.plantas && comunidade.plantas.length > 0) { %>
              <div class="border-t border-gray-200 pt-3 mt-3">
                <p class="text-xs font-semibold text-gray-700 mb-3">
                  Plantas (<%= comunidade.plantas.length %>):
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                  <% comunidade.plantas.forEach(planta => { %>
                    <div class="bg-white border border-gray-200 rounded-lg p-3 hover:shadow-md transition-shadow">
                      <div class="space-y-2">
                        <div>
                          <p class="text-xs font-semibold text-gray-500 uppercase">Nome Científico</p>
                          <p class="text-sm text-gray-900 font-medium italic">
                            <%= Array.isArray(planta.nomeCientifico) ? planta.nomeCientifico.join(', ') : planta.nomeCientifico %>
                          </p>
                        </div>
                        <div>
                          <p class="text-xs font-semibold text-gray-500 uppercase">Nome Vernacular</p>
                          <p class="text-sm text-gray-900">
                            <%= Array.isArray(planta.nomeVernacular) ? planta.nomeVernacular.join(', ') : planta.nomeVernacular %>
                          </p>
                        </div>
                        <div>
                          <p class="text-xs font-semibold text-gray-500 uppercase">Uso</p>
                          <p class="text-sm text-gray-700">
                            <%= Array.isArray(planta.tipoUso) ? planta.tipoUso.join(', ') : planta.tipoUso %>
                          </p>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- Reference Footer -->
    <footer class="border-t border-gray-200 pt-3 mt-4">
      <p class="text-xs text-gray-500">
        <% if (reference.createdAt) { %>
          Cadastrado em: <%= new Date(reference.createdAt).toLocaleDateString('pt-BR') %>
          <% if (reference.updatedAt && reference.createdAt && reference.updatedAt.toString() !== reference.createdAt.toString()) { %>
            | Atualizado em: <%= new Date(reference.updatedAt).toLocaleDateString('pt-BR') %>
          <% } %>
        <% } %>
      </p>
    </footer>
  </div>
</article>
