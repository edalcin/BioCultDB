<!-- Summary Cards Row -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

  <!-- Comunidades Card -->
  <div class="dashboard-card bg-gradient-to-br from-forest-500 to-forest-700 text-white">
    <div class="dashboard-card-header">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      <span class="dashboard-card-label">Total de Comunidades</span>
    </div>
    <div class="dashboard-card-value" id="community-count">-</div>
  </div>

  <!-- Referências Card -->
  <div class="dashboard-card bg-gradient-to-br from-blue-500 to-blue-700 text-white">
    <div class="dashboard-card-header">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <span class="dashboard-card-label">Referências Aprovadas</span>
    </div>
    <div class="dashboard-card-value" id="reference-count">-</div>
  </div>

  <!-- Plantas Card -->
  <div class="dashboard-card bg-gradient-to-br from-amber-500 to-amber-700 text-white">
    <div class="dashboard-card-header">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
      </svg>
      <span class="dashboard-card-label">Plantas Únicas</span>
    </div>
    <div class="dashboard-card-value" id="plant-count">-</div>
  </div>

  <!-- Autores Card -->
  <div class="dashboard-card bg-gradient-to-br from-purple-500 to-purple-700 text-white">
    <div class="dashboard-card-header">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <span class="dashboard-card-label">Autores Únicos</span>
    </div>
    <div class="dashboard-card-value" id="author-count">-</div>
  </div>

</div>

<!-- Maps Row -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

  <!-- Mapa de Referências por Estado -->
  <div class="card">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Referências por Estado</h3>
    <div id="map-references" class="w-full" style="min-height: 400px;"></div>
  </div>

  <!-- Mapa de Plantas por Estado -->
  <div class="card">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Plantas por Estado</h3>
    <div id="map-plants" class="w-full" style="min-height: 400px;"></div>
  </div>

</div>

<!-- Charts Row -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

  <!-- Publicações por Ano -->
  <div class="card">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Publicações por Ano</h3>
    <div id="chart-publications" class="w-full" style="min-height: 300px;"></div>
  </div>

  <!-- Top 10 Plantas -->
  <div class="card">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Top 10 Plantas Mais Citadas</h3>
    <div id="chart-top-plants" class="w-full" style="min-height: 300px;"></div>
  </div>

</div>

<!-- Tables Row -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

  <!-- Top Autores -->
  <div class="card">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Top 10 Autores</h3>
    <div id="table-authors"></div>
  </div>

  <!-- Top Comunidades -->
  <div class="card">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Top 10 Comunidades por Plantas</h3>
    <div id="table-communities"></div>
  </div>

</div>

<!-- Additional Stats Row -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  <!-- Referências com Mais Comunidades -->
  <div class="card">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Referências com Mais Comunidades</h3>
    <div id="table-ref-communities"></div>
  </div>

  <!-- Referências com Mais Plantas -->
  <div class="card">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Referências com Mais Plantas</h3>
    <div id="table-ref-plants"></div>
  </div>

</div>
