<!-- Sidebar -->
<aside class="w-64 bg-gray-100 border-r flex flex-col" :class="sidebarOpen ? '' : 'hidden md:flex'">
  <!-- Sidebar Header -->
  <div class="p-4 border-b bg-white">
    <button
      @click="newConversation"
      class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-forest-600 text-white rounded-lg hover:bg-forest-700 transition"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Nova Conversa
    </button>
  </div>

  <!-- Conversations List -->
  <div class="flex-1 overflow-y-auto">
    <template x-if="conversations.length === 0">
      <div class="p-4 text-center text-gray-500 text-sm">
        Nenhuma conversa ainda
      </div>
    </template>

    <template x-for="conv in conversations" :key="conv.id">
      <div
        @click="loadConversation(conv.id)"
        class="p-3 border-b cursor-pointer hover:bg-gray-200 transition group"
        :class="currentConversation.id === conv.id ? 'bg-forest-50 border-l-4 border-forest-600' : ''"
      >
        <div class="flex items-start justify-between gap-2">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-800 truncate" x-text="conv.title || 'Nova conversa'"></p>
            <p class="text-xs text-gray-500 truncate mt-1" x-text="formatDate(conv.createdAt)"></p>
          </div>
          <button
            @click.stop="deleteConversation(conv.id)"
            class="opacity-0 group-hover:opacity-100 p-1 text-gray-400 hover:text-red-600 transition"
            title="Excluir conversa"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </template>
  </div>

  <!-- Sidebar Footer -->
  <div class="p-4 border-t bg-white">
    <button
      @click="showSettings = true"
      class="w-full flex items-center justify-center gap-2 px-4 py-2 text-gray-700 border rounded-lg hover:bg-gray-50 transition"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      Configuracoes
    </button>
  </div>
</aside>

<!-- Mobile Sidebar Toggle -->
<button
  @click="sidebarOpen = !sidebarOpen"
  class="md:hidden fixed bottom-20 left-4 z-50 p-3 bg-forest-600 text-white rounded-full shadow-lg hover:bg-forest-700 transition"
>
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
  </svg>
</button>
