<div class="flex gap-3 mb-4" :class="message.role === 'user' ? 'flex-row-reverse' : ''">
  <!-- Avatar -->
  <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0"
       :class="message.role === 'user' ? 'bg-blue-600' : 'bg-forest-600'">
    <template x-if="message.role === 'user'">
      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
      </svg>
    </template>
    <template x-if="message.role === 'assistant'">
      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
      </svg>
    </template>
  </div>

  <!-- Message Content -->
  <div class="max-w-3xl"
       :class="message.role === 'user' ? 'bg-blue-600 text-white rounded-lg px-4 py-3' : 'bg-gray-100 rounded-lg px-4 py-3'">
    <template x-if="message.role === 'user'">
      <p class="whitespace-pre-wrap" x-text="message.content"></p>
    </template>
    <template x-if="message.role === 'assistant'">
      <div class="prose prose-sm max-w-none chat-message-content" x-html="renderMarkdown(message.content)"></div>
    </template>
    <p class="text-xs mt-2 opacity-60" x-text="formatTime(message.timestamp)"></p>
  </div>
</div>
