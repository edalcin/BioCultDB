<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> - BioCultDB</title>
  <link rel="stylesheet" href="/styles/main.css">
  <link rel="stylesheet" href="/styles/presentation/etnochat.css">
</head>
<body class="h-screen bg-gray-50 overflow-hidden" x-data="etnoChat()">

  <!-- Settings Modal -->
  <%- include('partials/chat-settings') %>

  <div class="h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-forest-700 text-white shadow-lg flex-shrink-0">
      <div class="container mx-auto px-4 py-3">
        <div class="flex items-center gap-4">
          <img src="/images/logo.png" alt="BioCultDB Logo" class="h-12 w-12">
          <div>
            <h1 class="text-xl font-bold"><%= contextName %></h1>
            <p class="text-forest-100 text-xs"><%= contextDescription %></p>
          </div>
        </div>
      </div>
    </header>

    <!-- Navigation Menu -->
    <nav class="bg-forest-600 text-white border-b border-forest-800 flex-shrink-0">
      <div class="container mx-auto px-4">
        <ul class="flex gap-0">
          <li>
            <a href="/" class="block px-6 py-2 hover:bg-forest-700 transition-colors border-b-2 border-transparent hover:border-forest-300 text-sm">
              Busca
            </a>
          </li>
          <li>
            <a href="/painel" class="block px-6 py-2 hover:bg-forest-700 transition-colors border-b-2 border-transparent hover:border-forest-300 text-sm">
              Painel
            </a>
          </li>
          <li>
            <a href="/etnochat" class="block px-6 py-2 hover:bg-forest-700 transition-colors border-b-2 border-forest-400 font-medium text-sm">
              etnoChat
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="flex-1 flex overflow-hidden">
      <!-- Sidebar -->
      <%- include('partials/chat-sidebar') %>

      <!-- Chat Area -->
      <main class="flex-1 flex flex-col bg-white">
        <!-- Messages Container -->
        <div class="flex-1 overflow-y-auto p-4" id="messages-container" x-ref="messagesContainer">
          <!-- Welcome Message (when no messages) -->
          <template x-if="currentConversation.messages.length === 0">
            <div class="h-full flex items-center justify-center">
              <div class="text-center max-w-md">
                <div class="w-20 h-20 bg-forest-100 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-10 h-10 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
                  </svg>
                </div>
                <h2 class="text-xl font-semibold text-gray-800 mb-2">Bem-vindo ao etnoChat</h2>
                <p class="text-gray-600 mb-4">
                  Pergunte sobre dados etnobotanicos: comunidades tradicionais, plantas medicinais, usos e referencias.
                </p>
                <div class="space-y-2">
                  <p class="text-sm text-gray-500">Experimente perguntar:</p>
                  <div class="flex flex-wrap gap-2 justify-center">
                    <button @click="sendSuggestion('Quais plantas sao mais usadas por quilombolas?')"
                            class="text-xs bg-forest-50 text-forest-700 px-3 py-1 rounded-full hover:bg-forest-100 transition">
                      Plantas usadas por quilombolas
                    </button>
                    <button @click="sendSuggestion('Quantas comunidades estao cadastradas na Bahia?')"
                            class="text-xs bg-forest-50 text-forest-700 px-3 py-1 rounded-full hover:bg-forest-100 transition">
                      Comunidades na Bahia
                    </button>
                    <button @click="sendSuggestion('Quais sao os tipos de uso de plantas mais comuns?')"
                            class="text-xs bg-forest-50 text-forest-700 px-3 py-1 rounded-full hover:bg-forest-100 transition">
                      Tipos de uso mais comuns
                    </button>
                  </div>
                </div>

                <!-- Settings reminder if not configured -->
                <template x-if="!settings.apiKey">
                  <div class="mt-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
                    <p class="text-sm text-amber-800">
                      <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                      </svg>
                      Configure sua chave de API para comecar
                    </p>
                    <button @click="showSettings = true" class="mt-2 text-sm text-amber-700 underline hover:text-amber-900">
                      Abrir Configuracoes
                    </button>
                  </div>
                </template>
              </div>
            </div>
          </template>

          <!-- Messages -->
          <template x-for="(message, index) in currentConversation.messages" :key="index">
            <%- include('partials/chat-message') %>
          </template>

          <!-- Streaming indicator -->
          <template x-if="isStreaming">
            <div class="flex gap-3 mb-4">
              <div class="w-8 h-8 bg-forest-600 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                </svg>
              </div>
              <div class="bg-gray-100 rounded-lg px-4 py-3 max-w-3xl">
                <div class="flex items-center gap-2">
                  <div class="typing-indicator">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                  <span class="text-sm text-gray-500">Pensando...</span>
                </div>
              </div>
            </div>
          </template>
        </div>

        <!-- Input Area -->
        <div class="border-t bg-gray-50 p-4 flex-shrink-0">
          <form @submit.prevent="sendMessage" class="max-w-4xl mx-auto">
            <div class="flex gap-3">
              <div class="flex-1 relative">
                <textarea
                  x-model="inputMessage"
                  x-ref="inputField"
                  @keydown.enter.prevent="if (!$event.shiftKey) sendMessage()"
                  placeholder="Digite sua pergunta sobre dados etnobotanicos..."
                  rows="1"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg resize-none focus:ring-2 focus:ring-forest-500 focus:border-transparent"
                  :disabled="isStreaming || !settings.apiKey"
                  x-init="$el.style.height = 'auto'; $el.style.height = $el.scrollHeight + 'px'"
                  @input="$el.style.height = 'auto'; $el.style.height = Math.min($el.scrollHeight, 150) + 'px'"
                ></textarea>
              </div>
              <button
                type="submit"
                :disabled="!inputMessage.trim() || isStreaming || !settings.apiKey"
                class="px-6 py-3 bg-forest-600 text-white rounded-lg hover:bg-forest-700 disabled:opacity-50 disabled:cursor-not-allowed transition flex items-center gap-2"
              >
                <template x-if="!isStreaming">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                  </svg>
                </template>
                <template x-if="isStreaming">
                  <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </template>
                <span class="sr-only">Enviar</span>
              </button>
            </div>
            <p class="text-xs text-gray-500 mt-2 text-center">
              <span x-text="settings.provider ? providers.find(p => p.id === settings.provider)?.name : 'Nenhum provedor'"></span>
              <span x-show="settings.model"> - <span x-text="settings.model"></span></span>
              <button type="button" @click="showSettings = true" class="ml-2 text-forest-600 hover:underline">
                Configurar
              </button>
            </p>
          </form>
        </div>
      </main>
    </div>
  </div>

  <!-- Alpine.js -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>

  <!-- Marked.js for Markdown rendering -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <!-- etnoChat JavaScript -->
  <script src="/scripts/etnochat.js"></script>

</body>
</html>
