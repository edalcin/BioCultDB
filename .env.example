# BioCultDB Environment Variables
# Copy this file to .env and update values for your environment
# For Unraid deployment, these variables are passed via the web interface

# ======================================
# REQUIRED VARIABLES
# ======================================

# SQLite database file path (JSON1 document store)
# ADR-005: one SQLite file per federated unit, shared by BioCultDB + BioCultTermos
# Default (container): /data/biocultdb.sqlite | Default (dev): ./data/unidade.sqlite
SQLITE_DB_PATH=/data/biocultdb.sqlite

# Node.js Environment
# Values: production, development
NODE_ENV=production

# ======================================
# BioCultTermos (unidade dual-app, ADR-001)
# ======================================

# HTTP Basic Auth credentials for the BioCultTermos admin/curation
# interface (port 4001). REQUIRED in production. Placeholder below —
# NUNCA committar senha real.
ADMIN_USERNAME=etnotermos
ADMIN_PASSWORD=troque-esta-senha

# Public vocabulary port (no auth)
# PUBLIC_PORT=4000

# Admin/curation port (HTTP Basic Auth via ADMIN_USERNAME/ADMIN_PASSWORD)
# ADMIN_PORT=4001

# Cron schedule for AcquisitionService (candidate concept extraction)
# ACQUISITION_CRON_SCHEDULE=0 3 * * *

# Directory for audio asset storage
# AUDIO_STORAGE_PATH=/data/audio


# URL pública do BioCultDB (interface de busca) — usada nos links de fontes bibliográficas
# BIOCULTDB_PUBLIC_URL=http://localhost:3003
# ======================================
# OPTIONAL VARIABLES (Defaults shown)
# ======================================

# Acquisition Interface (Data Entry) Port
# If omitted, defaults to 3001
# PORT_ACQUISITION=3001

# Curation Interface (Data Editing) Port
# If omitted, defaults to 3002
# PORT_CURATION=3002

# Presentation Interface (Public Search) Port
# If omitted, defaults to 3003
# PORT_PRESENTATION=3003

# ======================================
# DEVELOPMENT ONLY
# ======================================

# Uncomment below for local development with a different SQLite file:
# SQLITE_DB_PATH=./data/unidade.sqlite
# NODE_ENV=development
