# BioCultDB Environment Variables
# Copy this file to .env and update values for your environment
# For Unraid deployment, these variables are passed via the web interface

# ======================================
# REQUIRED VARIABLES
# ======================================

# SQLite database file path (JSON1 document store)
# ADR-005: one SQLite file per federated unit, shared by BioCultDB + BioCultTermos
# Default (container): /data/unidade.sqlite | Default (dev): ./data/unidade.sqlite
SQLITE_DB_PATH=/data/unidade.sqlite

# Node.js Environment
# Values: production, development
NODE_ENV=production

# ======================================
# OPTIONAL VARIABLES (Defaults shown)
# ======================================

# Acquisition Interface (Data Entry) Port
# If omitted, defaults to 3001
# PORT_ACQUISITION=3001

# Curation Interface (Data Editing) Port
# If omitted, defaults to 3002
# PORT_CURATION=3002

# Presentation Interface (Public Search) Port
# If omitted, defaults to 3003
# PORT_PRESENTATION=3003

# ======================================
# DEVELOPMENT ONLY
# ======================================

# Uncomment below for local development with a different SQLite file:
# SQLITE_DB_PATH=./data/unidade.sqlite
# NODE_ENV=development
